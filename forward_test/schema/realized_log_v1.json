{
  "schema_version": "realized_log_v1.1",
  "created_at": "2026-06-07",
  "supersedes": "realized_log_v1",
  "purpose": "OOS-IS 분리 + axis lag_gap 분리 + v12 raw / M8/M2/M6 filter variant 병렬 추적",
  "primary_key": "log_id",
  "columns": {
    "log_id": {
      "dtype": "str",
      "desc": "uuid: {entry_date}_{code}_{signal_source}"
    },
    "entry_date": {
      "dtype": "date",
      "desc": "T+0 entry"
    },
    "exit_date": {
      "dtype": "date",
      "desc": "nullable; hold 중 NaN"
    },
    "code": {
      "dtype": "str",
      "desc": "KRX 6-digit code"
    },
    "side": {
      "dtype": "str",
      "desc": "LONG / SHORT"
    },
    "signal_source": {
      "dtype": "str",
      "desc": "v12_RAW / v12+M8 / v12+M2 / v12+M6 / v12+M8M2M6"
    },
    "is_pollution_risk": {
      "dtype": "bool",
      "desc": "True if signal_source uses M2/M8/M6 (IS sweep_C 출처)"
    },
    "is_oos": {
      "dtype": "bool",
      "desc": "True if entry_date >= 2026-06-04"
    },
    "entry_px": {
      "dtype": "float",
      "desc": "entry day close"
    },
    "mtm_px": {
      "dtype": "float",
      "desc": "current mark price"
    },
    "mtm_date": {
      "dtype": "date",
      "desc": "latest mark date"
    },
    "gross_ret_mtm": {
      "dtype": "float",
      "desc": "(mtm_px/entry_px)-1"
    },
    "entry_cost": {
      "dtype": "float",
      "desc": "0.0015"
    },
    "exit_cost": {
      "dtype": "float",
      "desc": "0.0015 if CLOSED else 0.0"
    },
    "net_ret_mtm": {
      "dtype": "float",
      "desc": "gross - entry_cost - exit_cost"
    },
    "weight": {
      "dtype": "float",
      "desc": "1/10 = 0.10"
    },
    "hold_days_elapsed": {
      "dtype": "int",
      "desc": "biz days entry→mtm"
    },
    "hold_days_target": {
      "dtype": "int",
      "desc": "15 LONG / 5 SHORT"
    },
    "status": {
      "dtype": "str",
      "desc": "OPEN / CLOSED"
    },
    "regime_at_entry": {
      "dtype": "str",
      "desc": "v12 regime label (raw 불가 NaN 가능)"
    },
    "axis_M8": {
      "dtype": "float",
      "desc": "M8_z_inst_kospi at axis_ref_date"
    },
    "axis_M2": {
      "dtype": "float",
      "desc": "M2_z_vkospi_delta at axis_ref_date"
    },
    "axis_M6": {
      "dtype": "float",
      "desc": "M6_z_foreign_kospi_etf at axis_ref_date"
    },
    "axis_ref_date": {
      "dtype": "date",
      "desc": "axis 실제 참조 date (의도: entry_date-1bd; 실제: 그 이하 fallback)"
    },
    "axis_lag_bd": {
      "dtype": "int",
      "desc": "entry_date - axis_ref_date in biz days (의도 1, 실제 ≥1)"
    },
    "filter_M8_pass": {
      "dtype": "bool",
      "desc": "axis_M8 > 0.0"
    },
    "filter_M2_pass": {
      "dtype": "bool",
      "desc": "axis_M2 > -1.0"
    },
    "filter_M6_pass": {
      "dtype": "bool",
      "desc": "axis_M6 < 0.0"
    },
    "notes": {
      "dtype": "str",
      "desc": "free text"
    }
  },
  "pollution_rule": {
    "description": "M2/M8/M6 axis는 in-sample sweep_C 결과 기반 선택. OOS 자위 방지 위해 분리 추적.",
    "is_pollution_risk_true_when": [
      "v12+M8",
      "v12+M2",
      "v12+M6",
      "v12+M8M2M6"
    ],
    "is_pollution_risk_false_when": [
      "v12_RAW"
    ],
    "true_oos_metric_eligibility": "is_oos==True AND signal_source=='v12_RAW' 만 진짜 OOS 통계로 사용"
  },
  "lag_rule": {
    "description": "axis_lag_bd > 1 = T-1 의도와 실데이터 불일치. axis_v3 cutoff로 인한 forced fallback.",
    "ideal_lag_bd": 1,
    "current_known_issue": "axis_v3 cutoff = 2026-06-02 → 6/4 entry의 T-1(6/3) 데이터 없음 → T-2(6/2) 사용"
  }
}