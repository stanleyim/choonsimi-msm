{
  "schema_version": "realized_log_v1.2",
  "created_at": "2026-06-07",
  "supersedes": [
    "realized_log_v1",
    "realized_log_v1.1"
  ],
  "purpose": "OOS-IS 분리 + axis lag tracking + TAKEN/REJECTED 분리 기록. REJECTED row 보존으로 P(no-trade|filter) 추정 가능, edge unbiased.",
  "primary_key": "log_id",
  "columns": {
    "log_id": {
      "dtype": "str",
      "desc": "{entry_date}_{code}_{signal_source}"
    },
    "entry_date": {
      "dtype": "date",
      "desc": "T+0 entry 의도일"
    },
    "exit_date": {
      "dtype": "date",
      "desc": "nullable; OPEN/SKIPPED 시 NaT"
    },
    "code": {
      "dtype": "str",
      "desc": "KRX 6-digit code"
    },
    "side": {
      "dtype": "str",
      "desc": "LONG / SHORT"
    },
    "signal_source": {
      "dtype": "str",
      "desc": "v12_RAW / v12+M8 / v12+M2 / v12+M6 / v12+M8M2M6"
    },
    "signal_status": {
      "dtype": "str",
      "desc": "TAKEN / REJECTED_BY_FILTER"
    },
    "is_pollution_risk": {
      "dtype": "bool",
      "desc": "True if signal_source uses M2/M8/M6"
    },
    "is_oos": {
      "dtype": "bool",
      "desc": "True if entry_date >= 2026-06-04"
    },
    "entry_px": {
      "dtype": "float",
      "desc": "entry close; REJECTED 시 NaN"
    },
    "mtm_px": {
      "dtype": "float",
      "desc": "current mark; REJECTED 시 NaN"
    },
    "mtm_date": {
      "dtype": "date",
      "desc": "latest mark date; REJECTED 시 NaT"
    },
    "gross_ret_mtm": {
      "dtype": "float",
      "desc": "(mtm/entry)-1; REJECTED=0.0 (cash)"
    },
    "entry_cost": {
      "dtype": "float",
      "desc": "0.0015 if TAKEN else 0.0"
    },
    "exit_cost": {
      "dtype": "float",
      "desc": "0.0015 if CLOSED else 0.0"
    },
    "net_ret_mtm": {
      "dtype": "float",
      "desc": "gross - costs; REJECTED=0.0"
    },
    "weight": {
      "dtype": "float",
      "desc": "0.10 if TAKEN else 0.0"
    },
    "hold_days_elapsed": {
      "dtype": "int",
      "desc": "biz days entry→mtm; REJECTED=0"
    },
    "hold_days_target": {
      "dtype": "int",
      "desc": "15 LONG / 5 SHORT"
    },
    "status": {
      "dtype": "str",
      "desc": "OPEN / CLOSED / SKIPPED"
    },
    "regime_at_entry": {
      "dtype": "str",
      "desc": "v12 regime label (raw 미가용 시 NaN)"
    },
    "axis_M8": {
      "dtype": "float",
      "desc": "M8_z_inst_kospi at axis_ref_date"
    },
    "axis_M2": {
      "dtype": "float",
      "desc": "M2_z_vkospi_delta at axis_ref_date"
    },
    "axis_M6": {
      "dtype": "float",
      "desc": "M6_z_foreign_kospi_etf at axis_ref_date"
    },
    "axis_ref_date": {
      "dtype": "date",
      "desc": "axis 실제 참조일"
    },
    "axis_lag_bd": {
      "dtype": "int",
      "desc": "entry_date - axis_ref_date in biz days"
    },
    "filter_M8_pass": {
      "dtype": "bool",
      "desc": "axis_M8 > 0.0"
    },
    "filter_M2_pass": {
      "dtype": "bool",
      "desc": "axis_M2 > -1.0"
    },
    "filter_M6_pass": {
      "dtype": "bool",
      "desc": "axis_M6 < 0.0"
    },
    "notes": {
      "dtype": "str",
      "desc": "free text"
    }
  },
  "rejected_rule": {
    "description": "REJECTED_BY_FILTER row는 entry 자체가 발생 안 한 cash state. P(no-trade|filter) 추정 + edge unbiased 보장.",
    "trigger": "signal_source has filter AND filter_pass=False",
    "field_overrides": {
      "entry_px": "NaN",
      "mtm_px": "NaN",
      "mtm_date": "NaT",
      "gross_ret_mtm": 0.0,
      "entry_cost": 0.0,
      "exit_cost": 0.0,
      "net_ret_mtm": 0.0,
      "weight": 0.0,
      "hold_days_elapsed": 0,
      "status": "SKIPPED"
    },
    "metric_aggregation_rule": "variant별 portfolio return = mean(net_ret_mtm) over n=10 always. REJECTED=0이 cash 보유와 같은 기여 = 정확."
  },
  "pollution_rule": {
    "is_pollution_risk_true_when": [
      "v12+M8",
      "v12+M2",
      "v12+M6",
      "v12+M8M2M6"
    ],
    "is_pollution_risk_false_when": [
      "v12_RAW"
    ],
    "true_oos_metric_eligibility": "is_oos==True AND signal_source=='v12_RAW'"
  },
  "lag_rule": {
    "ideal_lag_bd": 1,
    "current_known_issue": "axis_v3 cutoff lag → axis_lag_bd>1 시 신뢰도 1단계 약화"
  }
}